# Copy to .env (in this directory) and fill in real values. Never commit .env.

# recurring_rules.startMinuteOfDay has no per-rule timezone field (PLAN.md
# "single-instance, single-timezone deployment") — this pins that single
# timezone to UTC explicitly rather than leaving it to whatever the host
# happens to be set to. index.ts asserts this at boot; don't remove it.
TZ=UTC

PORT=3300
DB_PATH=./data/dev.sqlite
# Only used to seed storage_config the very first time the server runs.
# Once that row exists, PUT /config/storage is the real source of truth —
# changing this afterward has no effect.
RECORDINGS_DIR=./data/recordings
# 32-byte key, base64-encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=
